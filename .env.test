# ==========================================================
# TEST ENVIRONMENT — Never use in production
# ==========================================================
APP_ENV=test
NODE_ENV=test

# In-memory SQLite — resets between test runs, no Supabase needed
DATABASE_URL=sqlite:///./test.db

# Sandbox gateways — no real money moves
PAYMENT_MOCK_MODE=true

# Test encryption key (32 bytes, base64 encoded)
APP_ENCRYPTION_KEY=dGVzdC1rZXktMzItYnl0ZXMteWVsbG93LXN1Ym0=

# Test blind index salt
BLIND_INDEX_SALT=test_blind_search_salt_for_unit_tests

# MFA — fixed bypass code allowed only in test env
MFA_TEST_BYPASS=123456

# Dummy secrets
SESSION_SECRET=test_session_secret
JWT_SECRET=test_jwt_secret

# FX — use hardcoded rates, skip live API
OPENEXCHANGE_API_KEY=test_skip_live_api