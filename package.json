{
  "name": "trueque-web",
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:alt": "node ./next-launcher.js dev",
    "dev:wrap": "node ./next-wrapper.js dev",
    "dev:test": "cross-env NEXT_PUBLIC_RUNTIME_ENV=testing next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "ci:test": "ts-node scripts/ping-test.ts",
    "migrate": "knex migrate:latest",
    "migrate:check": "ts-node scripts/validate-env.ts",
    "migrate:local": "npm run migrate:check && psql \"$DATABASE_URL\" -f ./migrations/20251017_0002_create_kyc_submissions_and_audit.sql",
    "migrate:rollback": "psql \"$DATABASE_URL\" -f ./migrations/20251017_0002_create_kyc_submissions_and_audit.down.sql",
    "kyc:harness": "ts-node -r tsconfig-paths/register src/scripts/kyc-dev-harness.ts",
    "kyc:status": "curl -s -H \"Authorization: Bearer $TOKEN\" http://localhost:3000/api/kyc/status | jq",
    "db:clean": "node scripts/db-cleanup.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.913.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "axios": "^1.13.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cookie": "^1.0.2",
    "crc": "^4.3.2",
    "dotenv": "^17.2.3",
    "form-data": "^4.0.4",
    "formidable": "^3.5.4",
    "i18next": "^25.6.0",
    "ioredis": "^5.9.2",
    "iron-session": "^8.0.4",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "next": "^15.5.4",
    "node-fetch": "^2.7.0",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.2.1",
    "redis": "^5.8.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "speakeasy": "^2.0.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/form-data": "^2.2.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/react-i18next": "^7.8.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.6",
    "identity-obj-proxy": "^3.0.0",
    "msw": "^2.12.1",
    "postcss": "^8.4.31",
    "prettier": "^3.1.0",
    "rollup": "^3.29.4",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
